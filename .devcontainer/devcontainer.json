{
  "name": "Multimodal RAG",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/app",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Application",
      "visibility": "public",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "pip install --no-cache-dir -r requirements.txt",
  "remoteUser": "root"
}
